class Retrowave < Formula
  desc "Keyboard-first terminal music player with album art and LRC lyrics"
  homepage "https://github.com/chinas130/RetroWave"
  url "@URL@"
  sha256 "@SHA256@"
  license "GPL-3.0-only"
  head "https://github.com/chinas130/RetroWave.git", branch: "main"

  depends_on "cmake" => :build
  depends_on "pkgconf" => :build
  depends_on "ffmpeg"
  depends_on "ncurses"

  on_linux do
    depends_on "alsa-lib"
  end

  def install
    system "cmake", "-S", ".", "-B", "build", *std_cmake_args
    system "cmake", "--build", "build"
    system "cmake", "--install", "build"
  end

  test do
    output = shell_output("#{bin}/retrowave #{testpath}/missing-audio-path 2>&1", 1)
    assert_match "No supported audio files were found.", output
  end
end
